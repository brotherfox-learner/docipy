# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example in repo)
.env*
!.env.example

# vercel
.vercel

# markdown (local notes / AI exports); keep repo docs tracked
*.md
!README.md
!src/theme-guide.md

# typescript
*.tsbuildinfo
next-env.d.ts
